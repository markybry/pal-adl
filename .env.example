# Database Configuration
# Copy this file to .env and fill in your actual values

DB_NAME=care_analytics
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=prefer

# Optional write-role credentials used by dashboard import/recalc.
# If omitted, the dashboard falls back to DB_USER/DB_PASSWORD.
# DB_WRITE_USER=care_app_rw
# DB_WRITE_PASSWORD=your_write_password_here

# Neon example:
# DB_NAME=neondb
# DB_USER=your_neon_user
# DB_PASSWORD=your_neon_password
# DB_HOST=ep-xxxxxxx.us-east-2.aws.neon.tech
# DB_PORT=5432
# DB_SSLMODE=require
